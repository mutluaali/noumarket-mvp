# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL - set this to your Vercel/custom domain in production
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Stripe server-side keys
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PREMIUM_SELLER_PRICE_ID=price_optional_premium_seller_monthly
PREMIUM_SELLER_MONTHLY_AMOUNT=9900

# Optional internal protection for cron endpoints
CRON_SECRET=change-this-long-random-secret

# V31 payment hardening

# Production payment providers (comma-separated). Omit stripe to hide Stripe checkout in production UI.
PAYMENT_PROVIDER_PRIORITY=bank_transfer,epaync

# Bank transfer instructions
BANK_TRANSFER_ACCOUNT_NAME=
BANK_TRANSFER_IBAN_OR_RIB=
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_INSTRUCTIONS=

# EpayNC (disabled until configured)
EPAYNC_ENABLED=false
EPAYNC_PAYMENT_URL=
EPAYNC_MERCHANT_ID=
EPAYNC_API_KEY=